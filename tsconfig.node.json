{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "types": [
      "@clack/prompts",
      "google-apps-script",
      "node",
      "parse5",
      "rolldown",
      "vite",
      "vitest"
    ],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",

    /* Linting */
    "strict": true
  },
  "include": ["src"],
  "exclude": ["src/client"]
}
