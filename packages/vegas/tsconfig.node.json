{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "types": [
      "@platformatic/vfs",
      "google-apps-script",
      "memfs",
      "node",
      "parse5",
      "vite",
      "vitest",
      "tsdown"
    ],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",

    /* Linting */
    "strict": true
  },
  "include": [
    "src/shared",
    "src/lib",
    "src/node/cli",
    "src/node/worker",
    "tsdown.config.ts",
    "rolldownLicensePlugin.ts"
  ]
}
