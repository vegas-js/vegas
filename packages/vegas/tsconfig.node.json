{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "types": ["google-apps-script", "memfs", "node", "parse5", "rolldown", "vite", "vitest"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",

    /* Linting */
    "strict": true
  },
  "include": ["src"],
  "exclude": ["src/client"]
}
