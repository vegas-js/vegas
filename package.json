{
  "name": "@vegasjs/vegas-monorepo",
  "private": true,
  "homepage": "https://vegasjs.dev",
  "license": "MIT",
  "author": "Yasushi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vegas-js/vegas.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest run",
    "build": "tsdown --config-loader unrun --workspace",
    "docs:dev": "pnpm --filter ./docs dev",
    "docs:build": "pnpm --filter ./docs build",
    "docs:preview": "pnpm --filter ./docs preview"
  },
  "devDependencies": {
    "@vegasjs/vegas": "workspace:*",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.33.0"
}
