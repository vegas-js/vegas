{
  "name": "@vegasjs/vegas-monorepo",
  "private": true,
  "homepage": "https://vegasjs.dev",
  "license": "MIT",
  "author": "Yasushi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vegas-js/vegas.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "oxlint --ignore-pattern 'packages/create-vegas/template-*'",
    "format": "oxfmt",
    "test": "vitest run",
    "build": "tsdown",
    "docs:dev": "pnpm --filter ./docs dev",
    "docs:build": "pnpm --filter ./docs build",
    "docs:preview": "pnpm --filter ./docs preview"
  },
  "devDependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "pnpm@10.32.1"
}
